def read_job():
job = modbus_get_signal_status("JOB", False)
#1 - cube, 2 - browser,  3 - 45
#4 - stereocab 2, 5 - sc 3, 6 - sc4
if job == 1:
  width = 362
  height = 362
  depth = 349
elif job == 2:
  width = 362
  height = 362
  depth = 235
elif job == 3:
  width = 724  
  height = 235
  depth = 349
elif job == 4:
  width = 724
  height = 235
  depth = 349
elif job == 5:
  width = 1086
  height = 235
  depth = 349
elif job == 6:
  width = 1448
  height = 235
  depth = 349
end
sleep(.2)
end
