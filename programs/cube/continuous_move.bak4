def Move_Continuous(direction):
 if (direction == "forward"):
    modbus_set_output_signal("DIRECTION_LOCAL", True, False)
  else: 
    modbus_set_output_signal("DIRECTION_LOCAL", False, False)
if (mm_old != 2):
    modbus_set_output_register("MOTION_MODE_LOC",2,False)
    while(mm_old == modbus_get_signal_status("MOTION_MODE_LOC")):
      sync()
    end
    while (not(modbus_get_signal_status("MOTION_MODE_LOC")==modbus_get_signal_status("MOTION_MODE_REM"))):
      sync()
    end
  end
end